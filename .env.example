APP_NAME=Park Agent
DATABASE_URL=postgresql+psycopg://park:park@db:5432/park_agent
REPORT_STORAGE_DIR=/app/storage

OPENAI_API_KEY=
# 官方 OpenAI 使用 https://api.openai.com/v1；第三方 OpenAI-compatible 中转站填它提供的 /v1 base URL
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
# responses: 官方 OpenAI 推荐；chat_completions: 大多数第三方 OpenAI-compatible 中转站更常支持
OPENAI_AGENT_API=chat_completions
# auto: 有 OPENAI_API_KEY 时使用真实 OpenAI-compatible API，否则使用 mock；openai: 强制真实 API；mock: 强制 mock
LLM_MODE=auto
